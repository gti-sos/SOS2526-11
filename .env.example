# =====================================================
# Variables OAuth2 / API por integrante
# =====================================================
# Copiar a .env y rellenar con valores reales.
# NO subir .env al repo.
# =====================================================

# ----------------------------
# JFM - Geoapify + HERE + TomTom
# (Solo API keys, sin OAuth)
# ----------------------------
GEOAPIFY_KEY=

HERE_CLIENT_ID=
HERE_CLIENT_SECRET=
TOMTOM_KEY=

# ----------------------------
# MRG - Nutritionix + USDA FoodData + API-Ninjas
# (Solo API keys, sin OAuth/refresh token)
# ----------------------------
NUTRITIONIX_APP_ID=
NUTRITIONIX_APP_KEY=

USDA_API_KEY=

API_NINJAS_KEY=

# ----------------------------
# TGG - NewsAPI + Google + LinkedIn
# ----------------------------
NEWSAPI_KEY=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REFRESH_TOKEN=
