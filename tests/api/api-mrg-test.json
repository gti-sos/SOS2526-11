    {
      "name": "DELETE All (Preparar DB)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 or 204', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 204]);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/alcohol-consumptions-per-capita",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alcohol-consumptions-per-capita"]
        }
      }
    },
    {
      "name": "Load Initial Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200 or 201', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              "pm.test('Response is an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "});",
              "pm.test('Array length is greater than 0', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json.length).to.be.above(0);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/alcohol-consumptions-per-capita/loadInitialData",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alcohol-consumptions-per-capita", "loadInitialData"]
        }
      }
    },
    {
      "name": "GET All",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test('Response is an array', function () {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.be.an('array');",
              "});",
              "pm.test('Each item has required fields', function () {",
              "    const json = pm.response.json();",
              "    json.forEach(function (item) {",
              "        pm.expect(item).to.have.property('nation');",
              "        pm.expect(item).to.have.property('date_year');",
              "        pm.expect(item).to.have.property('alcohol_litre');",
              "        pm.expect(item).to.have.property('recorded_consumption');",
              "        pm.expect(item).to.have.property('unrecorded_consumption');",
              "    });",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/alcohol-consumptions-per-capita",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alcohol-consumptions-per-capita"]
        }
      }
    },
    {
      "name": "GET Filtro (Albania)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
